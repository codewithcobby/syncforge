{
  "name": "syncforge-react",
  "version": "0.5.0",
  "description": "React bindings for SyncForge — provider and hooks for offline-first mutation sync.",
  "license": "MIT",
  "author": "Frank K. Abrokwa (codewithcobby)",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "react",
    "offline",
    "offline-first",
    "sync",
    "syncforge"
  ],
  "peerDependencies": {
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19",
    "syncforge": "^0.5.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "happy-dom": "^18.0.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "syncforge": "workspace:*",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false
}
